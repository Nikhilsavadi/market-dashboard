# Alpaca (required)
ALPACA_API_KEY=your_key_id_here
ALPACA_SECRET_KEY=your_secret_key_here

# Telegram (required for alerts)
# Get token from @BotFather → /newbot
# Get chat_id: message your bot then visit https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Manual scan trigger protection
TRIGGER_SECRET=choose_any_random_string

# ── Social Intelligence ───────────────────────────────────────────────────────
# Reddit API (free) — get from reddit.com/prefs/apps → create app → script type
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
# StockTwits — no key needed (public API)
# Twitter/X — not implemented (paid API required)

# ── Reddit API (free — get at reddit.com/prefs/apps, create "script" app) ──# Reddit username/password not needed — uses client credentials flow

SCAN_SECRET=your_scan_trigger_secret
